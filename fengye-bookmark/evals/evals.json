{
  "skill_name": "fengye-bookmark",
  "evals": [
    {
      "id": 1,
      "prompt": "帮我收藏这篇文章 https://www.paulgraham.com/greatwork.html",
      "expectations": [
        "Calls fengye-markdown-fetch with --download-media flag",
        "Creates a markdown file in ~/Documents/bookmarks/saved/",
        "File has YAML frontmatter with title, url, category, saved_date",
        "Images are downloaded to ~/Documents/bookmarks/assets/",
        "Image paths in markdown are relative (../assets/...)",
        "index.csv is updated with new entry",
        "Success message shows title, category, and saved path"
      ]
    },
    {
      "id": 2,
      "prompt": "Bookmark this tweet https://x.com/embedmon/status/2042487351608508819",
      "expectations": [
        "Calls fengye-x-fetch (not markdown-fetch) for X URL",
        "Creates a markdown file in ~/Documents/bookmarks/saved/",
        "File has YAML frontmatter",
        "index.csv is updated",
        "Success message shown"
      ]
    },
    {
      "id": 3,
      "prompt": "Save https://example.com for later",
      "expectations": [
        "Creates a markdown file in ~/Documents/bookmarks/saved/",
        "Filename uses at least 3 hyphened English words",
        "index.csv is updated with the URL",
        "Success message shown"
      ]
    },
    {
      "id": 4,
      "prompt": "收藏 https://en.wikipedia.org/wiki/Cat",
      "expectations": [
        "Fetches content with fengye-markdown-fetch",
        "Downloads images to assets/",
        "Markdown file uses relative asset paths",
        "Category is inferred (e.g. Science or Knowledge)",
        "index.csv has a description"
      ]
    },
    {
      "id": 5,
      "prompt": "帮我收藏这个 https://www.paulgraham.com/greatwork.html (this URL was already bookmarked in eval 1)",
      "expectations": [
        "Checks index.csv for duplicate",
        "Asks user whether to update or skip",
        "Does NOT create a new duplicate entry blindly"
      ]
    },
    {
      "id": 6,
      "prompt": "Bookmark https://news.ycombinator.com/",
      "expectations": [
        "Creates a markdown file",
        "Filename is descriptive (e.g. hacker-news-...)",
        "index.csv updated",
        "Success message shown"
      ]
    },
    {
      "id": 7,
      "prompt": "Save this article: https://developer.mozilla.org/en-US/docs/Web/JavaScript/Guide/Functions",
      "expectations": [
        "Fetches MDN content",
        "Category inferred as Programming or Technology",
        "Markdown has proper frontmatter structure",
        "index.csv updated"
      ]
    },
    {
      "id": 8,
      "prompt": "收藏 https://github.com/golang/go",
      "expectations": [
        "Fetches GitHub page content",
        "Saves as markdown with frontmatter",
        "index.csv updated",
        "Category inferred as Programming or Technology"
      ]
    },
    {
      "id": 9,
      "prompt": "Archive this blog post https://blog.pragmaticengineer.com/",
      "expectations": [
        "Fetches blog content via markdown-fetch",
        "Saves with descriptive filename",
        "Downloads any images",
        "index.csv updated"
      ]
    },
    {
      "id": 10,
      "prompt": "帮我把这个页面存到书签 https://www.paulgraham.com/avg.html",
      "expectations": [
        "Correctly identifies this as a web article (not X/Twitter)",
        "Uses fengye-markdown-fetch",
        "Creates bookmark with proper metadata",
        "index.csv updated with no CSV formatting errors"
      ]
    }
  ]
}
